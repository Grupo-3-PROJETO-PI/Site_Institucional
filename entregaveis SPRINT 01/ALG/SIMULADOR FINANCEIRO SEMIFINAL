<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <title>Simulador de Supermercado</title>
</head>

<style>
    #id_body {
        margin: 10;
        font-family: Arial, Helvetica, sans-serif;
        font-size: large;
        background-color: F4F4F4;
    }

    input, button {
        font-family: Arial, Helvetica, sans-serif;
        font-size: large;
    }
</style>

<body id="id_body">

    <h1 style="text-align: center; background-color: black; color: white;">
        Simulador Financeiro - SmartMarket
    </h1>
    <hr>

    <div style="text-align: center;">

        <p>
            <!--
            200 a 400 pessoas em supermercado pequeno/medio
            1000+ pessoas em supermercados de maior escala
            -->
            <label><b>Clientes por Dia:</b></label><br>
            <input type="number" id="clientes_id">
        </p>

        <p> <!-- ou TICKET MEDIO -->
            <label><b>Gasto médio por cliente (R$):</b></label><br>
            <input type="number" id="ticket_id" placeholder="80 - 150">
        </p>

        <p>
            <label><b>Dias de Funcionamento por mês:</b></label><br>
            <input type="number" id="dias_id">
        </p>

        <p>
            <label><b>Taxa de Conversão Atual (%):</b></label><br>
            <input type="number" id="taxa_id" value="70">
        </p>

        <button onclick="calcular()">Calcular</button>
        <hr>
    </div>

    <div id="resultados"></div>

</body>

<script>

function calcular() {

    let clientes = Number(clientes_id.value);
    let ticket = Number(ticket_id.value);
    let dias = Number(dias_id.value);
    let conversaoAtual = Number(taxa_id.value);

    // CUSTO DO SISTEMA
    let sensores = 2; // entrada + saída
    let arduinos = 1;
    let jumpers = 10;

    let custoSensores = sensores * 50;
    let custoArduino = arduinos * 150;
    let custoJumpers = jumpers * 2;

   // mao de obra + aplicaçao + nosso lucro
    let comissao = 5;

    let custoSistema = (custoSensores + custoArduino + custoJumpers) * comissao;

    // MELHORIA DO SISTEMA
    let perdaAtual = 100 - conversaoAtual;

    // 10% a 30% dos clientes desistem por filas longas
// Melhorias de fluxo recuperam 20% a 40% dessas desistências
    let eficiencia = 0.25;

    let aumento = perdaAtual * eficiencia;
    let novaConversao = conversaoAtual + aumento;

    if (novaConversao > 100) {
        novaConversao = 100;
    }

    // RECEITAS
    let receitaMax = clientes * ticket * dias;

    let receitaAtual = receitaMax * (conversaoAtual / 100);
    let receitaNova = receitaMax * (novaConversao / 100);

    let perdaMes = receitaMax - receitaAtual;

    let ganho = receitaNova - receitaAtual;

    let payback = 0;

    if (ganho > 0) {
        payback = custoSistema / ganho;
    } else {
        payback = 0;
    }

    let html = `
    <h1 style="text-align:center;">Resultados da Simulação</h1>

    <h2>Visão Geral:</h2>
    <p>Clientes por dia: <b>${clientes}</b></p>
    <p>Ticket médio: <b>R$${ticket.toFixed(2)}</b></p>
    <p>Receita mensal atual: <b>R$${receitaAtual.toFixed(2)}</b></p>
    <p>Investimento no sistema: <b>R$${custoSistema.toFixed(2)}</b></p>

    <h2>Análise de Perdas:</h2>
    <p>Perda mensal estimada: <span style="color:red;"><b>R$${perdaMes.toFixed(2)}</b></span></p>

    <h2>Impacto do Sistema:</h2>
    <p>Conversão atual: <b>${conversaoAtual}%</b></p>
    <p>Nova conversão: <span style="color:green;"><b>${novaConversao.toFixed(2)}%</b></span></p>

    <p>Nova receita mensal: <b>R$${receitaNova.toFixed(2)}</b></p>
    <p>Ganho mensal: <span style="color:green;"><b>R$${ganho.toFixed(2)}</b></span></p>

    <p>Payback: <b>${payback.toFixed(2)} meses</b></p>
    `;

    resultados.innerHTML = html;
}

</script>

</html>
